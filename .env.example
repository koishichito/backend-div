# ===== Quiz SNS API 環境変数 =====
# このファイルを .env にコピーして値を埋める:  cp .env.example .env
# .env は .gitignore 済み(コミットしないこと)

# --- DB サーバ(53 番)---
# 3 台構成では host を 192.168.0.53 にする
DATABASE_URL=mysql+pymysql://quiz_user:quiz_pass@192.168.0.53:3306/quiz_db?charset=utf8mb4

# --- Keycloak サーバ(51 番)---
# トークン検証の issuer / JWKS はこの URL から導出される。
# start-dev では iss が「トークンを取得した経路の host」に追従するため、
# トークン取得も検証もこの同じ URL 経由で行うこと。
KEYCLOAK_SERVER_URL=http://192.168.0.51:8080/
KEYCLOAK_REALM=test
KEYCLOAK_CLIENT_ID=test

# フロント等がブラウザでトークンを取得する公開 URL(検証には未使用・任意)
KEYCLOAK_PUBLIC_URL=http://192.168.0.51:8080

# KEYCLOAK_AUDIENCE は設定しない。
# Keycloak 既定の access token は aud="account" のため、client_id 等を入れると
# aud 検証に失敗する。

# --- CORS(フロントのオリジンをカンマ区切り)---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- リバースプロキシ配下のときだけ設定(例: /proxy/8099)。直接公開なら未設定 ---
# ROOT_PATH=
